{
  "crons": [
    {
      "path": "/api/cron/riot-sync",
      "schedule": "0 */6 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.deathmarkesport.com/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "deathmarkesport.org"
        }
      ]
    }
  ]
}
